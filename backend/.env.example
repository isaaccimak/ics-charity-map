APP_NAME=UniConnect API
ENVIRONMENT=development

# Supabase Postgres
# Use the direct database connection string from your Supabase project settings.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/uniconnect

JWT_SECRET_KEY=change-this-secret-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:5173
